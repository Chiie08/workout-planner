doctype html
html
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title Workout Planner

    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    )

    link(
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    )

  body#pageBody(style="background: linear-gradient(to right, #fff0f5, #ffe4ec);")
    .container.mt-5

      .text-end.mb-3
        button.btn.btn-outline-dark.rounded-circle.me-2(type="button" onclick="setDarkMode()")
          i.bi.bi-moon-stars-fill

        button.btn.btn-outline-secondary.rounded-circle(type="button" onclick="setLightMode()")
          i.bi.bi-brightness-high

      .text-center.mb-5
        img(
          src="/images/fitness-workout-healthy.png"
          alt="Workout Planner"
          style="width:120px;border-radius:20px;"
        )

        h1.display-2.fw-bold.mt-3(
          style="color:#9b5de5;text-shadow:2px 2px 6px rgba(0,0,0,0.15);"
        )
          | Workout Planner

        p.lead.text-muted.mt-3
          | トレーニング内容を記録し、
          br
          | 自分の成長を管理するためのアプリ

        p(style="color:#9b5de5;")
          | Created by Chie Kakizawa

        h4.mt-4.text-primary
          | 総トレーニング数：
          = totalWorkouts

      .card.shadow-lg.border-0.mb-4(style="border-radius:20px;")
        .card-body
          form(method="post" action="/create")

            .mb-3
              label.form-label 名前
              input.form-control(type="text" name="name" placeholder="名前" required)

            .mb-3
              label.form-label 日付
              input.form-control(type="date" name="workoutDate" required)

            .mb-3
              label.form-label 部位
              select.form-select(name="bodyPart")
                option 胸
                option 背中
                option 脚
                option 肩
                option 腕
                option 腹筋

            .mb-3
              label.form-label 種目
              input.form-control(type="text" name="exercise" placeholder="Bench Press" required)

            .mb-3
              label.form-label 重量（kg）
              input.form-control(type="number" name="weight" placeholder="40" required)

            .mb-3
              label.form-label 回数
              input.form-control(type="number" name="reps" placeholder="10" required)

            .mb-3
              label.form-label セット数
              input.form-control(type="number" name="sets" placeholder="3" required)

            button.btn.w-100(type="submit" style="background:#7c3aed;color:white;")
              | 登録

      each workout in workouts
        .card.shadow-sm.mb-3
          .card-body

            h4.card-title.text-primary
              = workout.name

            p.mb-1
              strong 日付：
              = new Date(workout.workoutDate).toISOString().slice(0,10)

            p.mb-1
              strong 部位：
              = workout.bodyPart

            p.mb-1
              strong 種目：
              = workout.exercise

            p.mb-1
              strong 重量：
              = workout.weight + "kg"

            p.mb-1
              strong 回数：
              = workout.reps + "回"

            p.mb-3
              strong セット数：
              = workout.sets + "セット"

            .text-end
              form(method="post" action="/delete")
                input(type="hidden" name="id" value=workout.id)

                button.btn.btn-danger(type="submit")
                  i.bi.bi-trash
                  |  削除

    script.
      function setDarkMode() {
        document.body.style.background = "#121212";
        document.body.style.color = "white";
        localStorage.setItem("theme", "dark");
      }

      function setLightMode() {
        document.body.style.background =
          "linear-gradient(to right, #fff0f5, #ffe4ec)";
        document.body.style.color = "black";
        localStorage.setItem("theme", "light");
      }

      window.onload = function () {
        const theme = localStorage.getItem("theme");

        if (theme === "dark") {
          setDarkMode();
        }
      };