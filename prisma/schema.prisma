generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workout {
  id          Int      @id @default(autoincrement())
  name        String
  workoutDate DateTime
  bodyPart    String
  exercise    String
  weight      Int
  reps        Int
  sets        Int
  createdAt   DateTime @default(now())
}